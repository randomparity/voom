                  filter:
                    LangIn:
                      - jpn
              - Not:
                  Exists:
                    target: subtitle
                    filter:
                      LangIn:
                        - eng
          then_actions:
            - Warn: "Japanese audio but no English subtitles in {filename}"
          else_actions: []
      - Rules:
          mode: first
          rules:
            - name: multi-language
              when:
                condition: AudioIsMultiLanguage
                then_actions:
                  - Warn: "Multiple audio languages in {filename}"
