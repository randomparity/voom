  - name: normalize
    skip_when: ~
    depends_on:
      - containerize
    run_if: ~
    on_error: ~
    operations:
      - Actions:
          target: audio
          settings:
            - - clear_all_default
              - Bool: true
            - - clear_all_forced
              - Bool: true
            - - clear_all_titles
              - Bool: true
      - Actions:
          target: subtitle
          settings:
            - - clear_all_default
              - Bool: true
            - - clear_all_forced
              - Bool: true
      - Keep:
          target: audio
          filter:
            LangIn:
              - eng
              - jpn
              - und
      - Keep:
          target: subtitles
          filter:
            And:
              - LangIn:
                  - eng
              - Not: Commentary
      - Remove:
          target: attachments
          filter:
            Not: Font
      - Order:
          - video
          - audio_main
          - audio_alternate
          - subtitle_main
          - subtitle_forced
          - audio_commentary
          - subtitle_commentary
          - attachment
      - Defaults:
          - - audio
            - first_per_language
          - - subtitle
            - none
