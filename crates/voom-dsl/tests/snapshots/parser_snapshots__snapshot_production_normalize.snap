  - name: audio_compat
    skip_when: ~
    depends_on:
      - normalize
    run_if: ~
    on_error: ~
    operations:
      - Synthesize:
          name: Stereo AAC
          settings:
            - Codec: aac
            - Channels:
                Ident: stereo
            - Source:
                And:
                  - CodecIn:
                      - truehd
                      - dts_hd
                      - flac
