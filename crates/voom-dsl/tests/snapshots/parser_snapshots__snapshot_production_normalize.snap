            - Ident: h265
    depends_on: []
    run_if: ~
    on_error: ~
    operations:
      - Transcode:
          target: video
          codec: hevc
          settings:
            - - crf
              - Number:
                  - 20
                  - "20"
            - - preset
              - Ident: medium
            - - max_resolution
