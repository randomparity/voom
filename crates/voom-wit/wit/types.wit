interface types {
    // NOTE: media-file and track are not yet used at the WASM boundary;
    // the actual interface passes MessagePack blobs in list<u8>.

    record media-file {
        path: string,
        size: u64,
        content-hash: option<string>,
        container: string,
        duration: float64,
        bitrate: option<u32>,
        tracks: list<track>,
        tags: list<key-value>,
        plugin-metadata: list<plugin-metadata-entry>,
    }

    record track {
        index: u32,
        track-type: track-type,
        codec: string,
        language: string,
        title: string,
        is-default: bool,
        is-forced: bool,
        channels: option<u32>,
        channel-layout: option<string>,
        sample-rate: option<u32>,
        bit-depth: option<u32>,
        width: option<u32>,
        height: option<u32>,
        frame-rate: option<float64>,
        is-vfr: bool,
        is-hdr: bool,
        hdr-format: option<string>,
        pixel-format: option<string>,
    }

    enum track-type {
        video,
        audio-main,
        audio-alternate,
        audio-commentary,
        audio-music,
        audio-sfx,
        audio-non-speech,
        subtitle-main,
        subtitle-forced,
        subtitle-commentary,
        attachment,
    }

    record key-value {
        key: string,
        value: string,
    }

    record plugin-metadata-entry {
        plugin-name: string,
        data: list<u8>,
    }

    // --- Plan types ---

    record plan {
        policy-name: string,
        phase-name: string,
        actions: list<planned-action>,
        warnings: list<string>,
        skip-reason: option<string>,
    }

    record planned-action {
        operation: operation-type,
        track-index: option<u32>,
        parameters: list<u8>,
        description: string,
    }

    enum operation-type {
        set-default,
        clear-default,
        set-forced,
        clear-forced,
        set-title,
        set-language,
        remove-track,
        reorder-tracks,
        convert-container,
        transcode-video,
        transcode-audio,
        synthesize-audio,
        set-container-tag,
    }

    record phase-result {
        phase-name: string,
        outcome: phase-outcome,
        actions: list<action-result>,
        file-modified: bool,
        skip-reason: option<string>,
        duration-ms: u64,
        temp-path: option<string>,
    }

    enum phase-outcome {
        pending,
        completed,
        skipped,
        failed,
    }

    record action-result {
        operation: operation-type,
        success: bool,
        description: string,
        error-message: option<string>,
    }

    // --- File transition types ---

    enum transition-source {
        discovery,
        voom,
        external,
        unknown,
    }

    enum processing-outcome {
        success,
        failure,
        skipped,
    }

    record metadata-snapshot {
        container: string,
        video-tracks: u32,
        audio-tracks: u32,
        subtitle-tracks: u32,
        codecs: list<string>,
        resolution: option<string>,
        duration-secs: float64,
    }

    record file-transition {
        id: string,
        file-id: string,
        path: string,
        from-hash: option<string>,
        to-hash: string,
        from-size: option<u64>,
        to-size: u64,
        source: transition-source,
        source-detail: option<string>,
        plan-id: option<string>,
        created-at: string,
        duration-ms: option<u64>,
        actions-taken: option<u32>,
        tracks-modified: option<u32>,
        outcome: option<processing-outcome>,
        policy-name: option<string>,
        phase-name: option<string>,
        metadata-snapshot: option<metadata-snapshot>,
    }

    // --- Event types ---

    record event-data {
        event-type: string,
        payload: list<u8>,
    }

    record event-result {
        plugin-name: string,
        produced-events: list<event-data>,
        data: option<list<u8>>,
        claimed: bool,
        execution-error: option<string>,
        execution-detail: option<list<u8>>,
    }

    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    record header {
        name: string,
        value: string,
    }

    record http-response {
        status: u16,
        headers: list<header>,
        body: list<u8>,
    }

    record tool-output {
        exit-code: s32,
        stdout: list<u8>,
        stderr: list<u8>,
    }

}
