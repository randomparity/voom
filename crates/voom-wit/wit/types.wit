interface types {
    // ASPIRATIONAL: media-file, track, and container records are defined for
    // future typed WASM boundary use. The actual boundary currently passes
    // MessagePack-serialized voom-domain types in list<u8> blobs.

    record media-file {
        path: string,
        size: u64,
        content-hash: option<string>,
        container: string,
        duration: float64,
        bitrate: option<u32>,
        tracks: list<track>,
        tags: list<key-value>,
        plugin-metadata: list<plugin-metadata-entry>,
    }

    record track {
        index: u32,
        track-type: track-type,
        codec: string,
        language: string,
        title: string,
        is-default: bool,
        is-forced: bool,
        channels: option<u32>,
        channel-layout: option<string>,
        sample-rate: option<u32>,
        bit-depth: option<u32>,
        width: option<u32>,
        height: option<u32>,
        frame-rate: option<float64>,
        is-vfr: bool,
        is-hdr: bool,
        hdr-format: option<string>,
        pixel-format: option<string>,
    }

    enum track-type {
        video,
        audio-main,
        audio-alternate,
        audio-commentary,
        audio-music,
        audio-sfx,
        audio-non-speech,
        subtitle-main,
        subtitle-forced,
        subtitle-commentary,
        attachment,
    }

    // UNUSED: container enum is defined for future typed boundary use but is
    // not referenced by any interface. Media container info currently flows as
    // a string field on media-file or in MessagePack payloads.
    enum container {
        mkv,
        mp4,
        avi,
        webm,
        flv,
        wmv,
        mov,
        ts,
        other,
    }

    record key-value {
        key: string,
        value: string,
    }

    record plugin-metadata-entry {
        plugin-name: string,
        data: list<u8>,
    }

    // --- Plan types ---

    record plan {
        policy-name: string,
        phase-name: string,
        actions: list<planned-action>,
        warnings: list<string>,
        skip-reason: option<string>,
    }

    record planned-action {
        operation: operation-type,
        track-index: option<u32>,
        parameters: list<u8>,
        description: string,
    }

    enum operation-type {
        set-default,
        clear-default,
        set-forced,
        clear-forced,
        set-title,
        set-language,
        remove-track,
        reorder-tracks,
        convert-container,
        transcode-video,
        transcode-audio,
        synthesize-audio,
        set-container-tag,
    }

    record phase-result {
        phase-name: string,
        outcome: phase-outcome,
        actions: list<action-result>,
        file-modified: bool,
        skip-reason: option<string>,
        duration-ms: u64,
    }

    enum phase-outcome {
        pending,
        completed,
        skipped,
        failed,
    }

    record action-result {
        operation: operation-type,
        success: bool,
        description: string,
        error-message: option<string>,
    }

    // --- Event types ---

    record event-data {
        event-type: string,
        payload: list<u8>,
    }

    record event-result {
        plugin-name: string,
        produced-events: list<event-data>,
        data: option<list<u8>>,
    }

    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    record header {
        name: string,
        value: string,
    }

    record http-response {
        status: u16,
        headers: list<header>,
        body: list<u8>,
    }

    record tool-output {
        exit-code: s32,
        stdout: list<u8>,
        stderr: list<u8>,
    }

    // UNUSED: file-filters record is defined for future typed list-files use
    // but is not referenced by any interface. The actual list-files signature
    // takes (dir: string, pattern: string).
    record file-filters {
        extensions: list<string>,
        min-size: option<u64>,
        max-size: option<u64>,
    }
}
