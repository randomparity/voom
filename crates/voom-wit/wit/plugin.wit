interface plugin {
    use types.{event-data, event-result};

    record plugin-info {
        name: string,
        version: string,
        description: option<string>,
        author: option<string>,
        license: option<string>,
        homepage: option<string>,
        capabilities: list<capability>,
    }

    variant capability {
        discover(discover-cap),
        introspect(introspect-cap),
        evaluate-policy,
        execute(execute-cap),
        store(store-cap),
        detect-tools,
        manage-jobs,
        serve-http,
        orchestrate-phases,
        backup,
        enrich-metadata(enrich-cap),
        transcribe,
        synthesize,
        generate-subtitle,
        health-check,
    }

    record discover-cap {
        schemes: list<string>,
    }

    record introspect-cap {
        formats: list<string>,
    }

    record execute-cap {
        operations: list<string>,
        formats: list<string>,
    }

    record enrich-cap {
        source: string,
    }

    record store-cap {
        backend: string,
    }

    /// Return plugin identity and capabilities.
    get-info: func() -> plugin-info;

    /// Check if this plugin handles the given event type.
    handles: func(event-type: string) -> bool;

    /// Process an event and optionally return a result.
    on-event: func(event: event-data) -> option<event-result>;

    /// Handle a Call dispatched by the host. The call is MessagePack-encoded
    /// (matching how event payloads cross the WIT boundary). Returns either a
    /// MessagePack-encoded CallResponse on success or an error message string.
    ///
    /// For streaming Calls (e.g. scan-library), the WASM plugin uses
    /// `emit-call-item` (host fn) to push items to the caller's receiver and
    /// `call-is-cancelled` (host fn) to poll the cancellation token. The
    /// payload `list<u8>` for streaming Calls omits the host-only fields
    /// (sink, cancel, root-done senders).
    on-call: func(call: list<u8>) -> result<list<u8>, string>;
}
